{
  "name": "linkdup",
  "version": "0.1.0",
  "description": "LinkedIn content generator — self-hosted CLI + web UI",
  "type": "module",
  "bin": {
    "linkdup": "./bin/linkdup.js"
  },
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently -k -n api,ui -c blue,magenta \"DEV=1 tsx src/cli.ts\" \"vite --config client/vite.config.ts\"",
    "dev:onboard": "tsx src/cli.ts",
    "dev:api": "DEV=1 tsx src/cli.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "tsc && vite build --config client/vite.config.ts",
    "start": "node dist/cli.js",
    "test": "vitest --passWithNoTests"
  },
  "keywords": [
    "linkedin",
    "content-generation",
    "ai",
    "openrouter"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "keytar": "^7.9.0",
    "multer": "^2.1.1",
    "open": "^11.0.0",
    "pdf-parse": "^2.4.5",
    "youtube-transcript": "^1.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
