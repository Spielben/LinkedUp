{
  "name": "linkdup",
  "version": "0.1.0",
  "description": "LinkedIn content generator — self-hosted CLI + web UI",
  "type": "module",
  "bin": {
    "linkdup": "./bin/linkdup.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "tsc && vite build --config client/vite.config.ts",
    "start": "node dist/cli.js",
    "test": "vitest"
  },
  "keywords": [
    "linkedin",
    "content-generation",
    "ai",
    "openrouter"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "keytar": "^7.9.0",
    "open": "^11.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
