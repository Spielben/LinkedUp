# Copy to .env.production and fill in secrets (never commit .env.production)
# chmod 600 .env.production on the server

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx

# Must match LinkedIn “Authorized redirect URLs” exactly (HTTPS URL of your public host + this path)
LINKEDIN_REDIRECT_URI=https://linkdup.YOURDOMAIN.com/api/linkedin/callback

LINKEDIN_CLIENT_ID=xxxxxxxxxxxxxxxx
LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Leave empty — filled automatically after OAuth in the app
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_PERSON_URN=

APIFY_API_KEY=
PORT=3000
USE_ENV_CREDENTIALS=true

# Ingest web HTTPS : 0 = désactiver le second essai sans vérification du cert (par défaut activé, sites à chaîne TLS incomplète).
# LINKDUP_WEB_FETCH_TLS_RETRY_INSECURE=0
# 1 = accepter tout certificat dès le premier appel (déconseillé, risque MITM).
# LINKDUP_INSECURE_WEB_FETCH=

# Si tu définis NODE_OPTIONS, tu écrases la valeur du Dockerfile : inclure --use-openssl-ca si tu comptes sur le magasin OpenSSL pour *tout* Node.
# NODE_OPTIONS=--use-openssl-ca
# CA d'entreprise (PEM) : lu par l'app et ajouté au bundle système du conteneur (voir docs/VPS-HOSTINGER.md).
# NODE_EXTRA_CA_CERTS=
# Remplacer le bundle CA principal (rare ; par défaut le conteneur utilise /etc/ssl/certs/ca-certificates.crt).
# SSL_CERT_FILE=

# HTTP Basic Auth — set AUTH_OWNER_PASS to enable (leave empty to disable)
AUTH_OWNER_USER=ben
AUTH_OWNER_PASS=
# Second account for a collaborator (optional — leave both empty to disable)
AUTH_COLLAB_USER=collab
AUTH_COLLAB_PASS=
